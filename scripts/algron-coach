#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
cd "$PROJECT_ROOT"

# Git-Remote-Check: Warnung wenn Remote neuere Commits hat
if git rev-parse --git-dir &>/dev/null; then
    git fetch origin --quiet 2>/dev/null || true
    LOCAL=$(git rev-parse HEAD 2>/dev/null || true)
    REMOTE=$(git rev-parse origin/main 2>/dev/null || true)
    if [[ -n "$LOCAL" && -n "$REMOTE" && "$LOCAL" != "$REMOTE" ]]; then
        BEHIND=$(git rev-list --count HEAD..origin/main 2>/dev/null || echo "0")
        if [[ "$BEHIND" -gt 0 ]]; then
            echo ""
            echo "⚠  Remote hat $BEHIND neuere Commits. Willst du pullen? (j/n)"
            read -r ANSWER
            if [[ "$ANSWER" == "j" ]]; then
                git pull --ff-only origin main || echo "Pull fehlgeschlagen -- bitte manuell lösen."
            fi
            echo ""
        fi
    fi
fi

MODE="${1:-}"
shift || true
# Optionale Flags nach dem Modus: --mobile / --handoff [titel]
MOBILE=""
HANDOFF=""
TITLE=""
while [ $# -gt 0 ]; do
  case "$1" in
    --mobile) MOBILE=1 ;;
    --handoff) HANDOFF=1 ;;
    *) TITLE="$1" ;;
  esac
  shift
done

PROMPT_FILE="$PROJECT_ROOT/main-agent.md"
TALK_PROMPT="Sessionstart: Lies project-status.md und die progress/-Dateien (session-log.md, bestandsaufnahme.md, vision.md, action-plan.md), dann brief mich wo wir stehen. Falls alle leer: Starte die Bestandsaufnahme. Reminder: Sessionende → /commit aufrufen."
STRATEGY_PROMPT="Strategie-Modus: Du bist Andis strategischer Sparringspartner fuer die Algron/Henrik-Lage. Lies strategy/ (alle Dateien) plus project-status.md und die progress/-Dateien. Pruefe context/handovers/ auf aktive Handovers (status: active) -- laufende Arbeitsstraenge, nimm sie als Ausgangspunkt. Dann brief Andi wo die Strategie steht. Reminder: Sessionende → /commit aufrufen."
ADMIN_PROMPT="Admin-Modus: Du bist im Wartungsmodus mit Andy (Team-Betreuer). Lies project-status.md und CLAUDE.md, pruefe context/handovers/ auf aktive Handovers (status: active), dann frag was ansteht. Kein Coach-Verhalten noetig. Reminder: Sessionende → /commit aufrufen."

# Cockpit-Hülle für --mobile / --handoff.
COCKPIT="$HOME/workspace/products/mobile-cockpit/scripts/clauderc"

# Startet die Agenten-Zeile. Ohne Flag: lokal (wie bisher). Mit --mobile: frisch
# durch die Cockpit-Hülle, MIT Starter-Prompt. Mit --handoff: die gerade
# verlassene Session via `claude --continue` fortsetzen — OHNE Starter-Prompt,
# aber mit demselben System-Prompt (Persona bleibt beim Resume erhalten).
#   $1 = Default-Name, $2 = Starter-Prompt, Rest = claude-Zeile (ohne Starter)
launch_agent() {
  local def="$1" starter="$2"; shift 2
  local name="${TITLE:-$def}"
  if [ -n "$HANDOFF" ]; then
    exec "$COCKPIT" handoff "$name" -- "$@"
  elif [ -n "$MOBILE" ]; then
    exec "$COCKPIT" run "$name" -- "$@" "$starter"
  else
    exec "$@" "$starter"
  fi
}

case "$MODE" in
  talk)
    launch_agent "algron-coach – talk" "$TALK_PROMPT" \
      claude --system-prompt-file "$PROMPT_FILE"
    ;;
  strategy)
    launch_agent "algron-coach – strategy" "$STRATEGY_PROMPT" \
      claude --system-prompt-file "$PROJECT_ROOT/strategy/strategy-agent.md"
    ;;
  admin)
    launch_agent "algron-coach – admin" "$ADMIN_PROMPT" \
      claude
    ;;
  --get-prompt)
    echo "$TALK_PROMPT"
    exit 0
    ;;
  *)
    echo "Usage: algron-coach <mode> [--mobile|--handoff [titel]]"
    echo ""
    echo "  talk      Sparring-Session mit Henrik (Coach-Modus)"
    echo "  strategy  Strategie-Sparring mit Andi (Andi-Zone, liest strategy/)"
    echo "  admin     Wartung & Architektur mit Andy"
    echo ""
    echo "  --mobile [titel]   Frisch mobil starten (tmux + Remote Control,"
    echo "                     in der Cockpit-App steuerbar; optionaler Titel)"
    echo "  --handoff [titel]  Gerade verlassene Session mobil weiterreichen"
    echo "                     (claude --continue, Persona bleibt; vorher Exit)"
    echo "  --get-prompt       Starter-Prompt ausgeben (fuer externe Apps)"
    exit 0
    ;;
esac
